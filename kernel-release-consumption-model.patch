+
+func isScaffoldTextFile(name string) bool {
+	switch filepath.Ext(name) {
+	case ".go", ".mod", ".sum", ".yaml", ".yml", ".toml", ".json", ".md", ".proto", ".sh", ".ps1", ".cmd", ".bat", ".mk", ".txt":
+		return true
+	}
+	switch filepath.Base(name) {
+	case "Makefile", "Dockerfile", ".gitignore", ".gitattributes":
+		return true
+	}
+	return false
+}

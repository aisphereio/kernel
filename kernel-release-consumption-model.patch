+++ b/cmd/kernel/internal/project/layout_test.go
@@ -48,3 +48,30 @@ func TestDefaultScaffoldOptionsIncludeKernelCapabilities(t *testing.T) {
 		t.Fatalf("unexpected defaults: %#v", opts)
 	}
 }
+
+func TestApplyScaffoldOptionsReplacesKernelVersion(t *testing.T) {
+	root := t.TempDir()
+	if err := os.WriteFile(filepath.Join(root, "go.mod"), []byte("require github.com/aisphereio/kernel __KERNEL_VERSION__\n"), 0o644); err != nil {
+		t.Fatal(err)
+	}
+	if err := os.WriteFile(filepath.Join(root, "Makefile"), []byte("KERNEL_VERSION ?= __KERNEL_VERSION__\n"), 0o644); err != nil {
+		t.Fatal(err)
+	}
+	if err := applyScaffoldOptions(root, ScaffoldOptions{KernelVersion: "v0.10.1"}); err != nil {
+		t.Fatal(err)
+	}
+	goMod, err := os.ReadFile(filepath.Join(root, "go.mod"))
+	if err != nil {
+		t.Fatal(err)
+	}
+	if string(goMod) != "require github.com/aisphereio/kernel v0.10.1\n" {
+		t.Fatalf("unexpected go.mod: %s", goMod)
+	}
+	mk, err := os.ReadFile(filepath.Join(root, "Makefile"))
+	if err != nil {
+		t.Fatal(err)
+	}
+	if string(mk) != "KERNEL_VERSION ?= v0.10.1\n" {
+		t.Fatalf("unexpected Makefile: %s", mk)
+	}
+}

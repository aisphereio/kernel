diff --git a/contextx/context.go b/contextx/context.go
new file mode 100644
index 0000000..de6b7e9
--- /dev/null
+++ b/contextx/context.go
@@ -0,0 +1,27 @@
+package contextx
+
+import (
+	"context"
+
+	"github.com/aisphereio/kernel/logx"
+)
+
+// Context is an optional ergonomic wrapper that enables ctx.Log(). It is kept
+// outside logx to avoid making logx depend on an application context package.
+type Context struct {
+	context.Context
+	fallback logx.Logger
+}
+
+func New(ctx context.Context, fallback logx.Logger) Context {
+	if ctx == nil {
+		ctx = context.Background()
+	}
+	return Context{Context: ctx, fallback: fallback}
+}
+
+func (c Context) Log() logx.Logger {
+	return logx.FromContextOr(c.Context, c.fallback)
+}
+
+func (c Context) GoContext() context.Context { return c.Context }
